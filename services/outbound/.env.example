# ============================================================================
# CERNIQ Outbound Engine — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── Database (shares the main CERNIQ database) ─────────────────────────────

OUTBOUND_DATABASE_URL=postgresql://cerniq:dev_password_change_in_prod@localhost:5433/cerniq

# ── SMTP / Email ────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=erwin@cerniq.com
FROM_NAME=Erwin Kiess

# ── Enrichment APIs (optional — agents degrade gracefully without these) ───

HUNTER_API_KEY=
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# ── Outreach Volume Limits ──────────────────────────────────────────────────

DAILY_EMAIL_LIMIT=50
DAILY_LINKEDIN_LIMIT=20

# ── Follow-up Timing (days) ────────────────────────────────────────────────

FOLLOWUP_1_DAYS=3
FOLLOWUP_2_DAYS=7

# ── FastAPI Server ──────────────────────────────────────────────────────────

OUTBOUND_API_HOST=0.0.0.0
OUTBOUND_API_PORT=8002
