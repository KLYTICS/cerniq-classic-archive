{
  "name": "@capex-cycle/api",
  "version": "1.0.0",
  "description": "Capex Cycle OS - High-performance API server built with Bun.js",
  "main": "server.ts",
  "scripts": {
    "start": "bun run server.ts",
    "dev": "bun --watch server.ts",
    "test": "bun test",
    "build": "bun build server.ts --compile --outfile capex-api",
    "lint": "eslint *.ts",
    "format": "prettier --write *.ts"
  },
  "keywords": [
    "quantitative-finance",
    "risk-management",
    "portfolio-optimization",
    "api",
    "bun"
  ],
  "author": "Capex Cycle Team",
  "license": "MIT",
  "dependencies": {
    "ioredis": "^5.3.2",
    "postgres": "^3.4.3",
    "nats": "^2.19.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
