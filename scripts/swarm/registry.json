      "scope_paths": ["docs/architecture/", "docs/api-contracts/", ".omx/state/approvals/"],
      "tier_overrides": {
        "max_auto": 2,
        "notes": "Architecture can approve cross-scope requests (Tier 2) but not prod actions"
      }
    },
    "qa-testing": {
      "terminal": "T-11",
      "bible": "docs/CERNIQ_Vol4_SWARM_MASTER_BIBLE.md §2-A",
