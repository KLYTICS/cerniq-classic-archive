{
  "$schema_version": 3,
  "doc": "Vol.4 100-CLI Swarm Dispatch Model v3. Maps CLIs across 14 department swarms to 11 terminals. Includes Autonomy Tier system (0-3+X). Coexists with Vol.3 50-terminal model at .cerniq/terminals.json.",
  "updated_at": "2026-04-16",
  "autonomy_tiers": {
    "0": { "name": "SILENT", "description": "Read, grep, test, typecheck, lint, health checks", "trace": "none" },
    "1": { "name": "AUTO+AUDIT", "description": "Code edits (claimed scope), branches, draft PRs, builds, staging deploys", "trace": ".omx/state/audit/" },
    "2": { "name": "AUTO+REVIEW", "description": "Merge to main (CI green), email drafts, new API routes, auth/schema changes", "trace": ".omx/state/approvals/pending/" },
    "3": { "name": "PRE-APPROVE", "description": "Prod deploy, prod migrations, customer emails, Stripe writes, secret rotation, COSSEC cert", "trace": ".omx/state/approvals/pending/ (blocks until approved)" },
    "X": { "name": "FORBIDDEN", "description": "Force push main, DROP without WHERE, hardcode secrets, self-approve PRs, Float for money", "trace": "refused + logged" }
  },
  "terminals": {
    "T-01": { "name": "Command & Control", "operator": "Erwin", "scope": "admin, approvals, overrides" },
    "T-02": { "name": "Engineering Backend", "operator": "swarm", "scope": "backend-node/src/" },
    "T-03": { "name": "Engineering Frontend", "operator": "swarm", "scope": "frontend/" },
    "T-04": { "name": "GTM / Sales", "operator": "swarm", "scope": "services/outbound/" },
    "T-05": { "name": "Monitoring & Alerts", "operator": "swarm", "scope": "health checks, uptime" },
    "T-06": { "name": "ALM / Quant", "operator": "swarm", "scope": "backend-node/src/alm/" },
    "T-07": { "name": "DevOps / Infra", "operator": "swarm", "scope": "infra, CI/CD, Railway, Vercel" },
    "T-08": { "name": "Compliance", "operator": "swarm", "scope": "COSSEC, NCUA, audit" },
    "T-09": { "name": "Product & RevOps", "operator": "swarm", "scope": "product strategy, Stripe, pipeline" },
    "T-10": { "name": "Dispatch / Erwin", "operator": "Erwin", "scope": "mission dispatch, fleet oversight" },
    "T-11": { "name": "QA & Testing", "operator": "swarm", "scope": "tests, e2e, coverage, regression" }
  },
  "swarms": {
    "engineering-backend": {
