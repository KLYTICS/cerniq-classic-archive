{
  "name": "cerniq-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint app components hooks lib types instrumentation.ts instrumentation-client.ts next.config.ts playwright.config.ts proxy.ts vitest.config.ts eslint.config.mjs && node scripts/verify-alm-registry.mjs",
    "verify:alm": "node scripts/verify-alm-registry.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --maxWorkers=1",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test e2e/production-critical.spec.ts",
    "test:e2e:preview": "sh -c 'test -n \"$PLAYWRIGHT_BASE_URL\" || { echo \"PLAYWRIGHT_BASE_URL is required\" >&2; exit 1; }; PLAYWRIGHT_SKIP_WEBSERVER=1 PLAYWRIGHT_ENABLE_CHECKOUT_SMOKE=1 PLAYWRIGHT_MOCK_CHECKOUT=1 PLAYWRIGHT_BACKEND_URL=\"${PLAYWRIGHT_BACKEND_URL:-https://api.cerniq.io}\" playwright test e2e/production-critical.spec.ts'",
    "test:e2e:production": "PLAYWRIGHT_SKIP_WEBSERVER=1 PLAYWRIGHT_BASE_URL=https://cerniq.io PLAYWRIGHT_BACKEND_URL=https://api.cerniq.io playwright test e2e/production-critical.spec.ts --grep-invert @preview-only",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.46.0",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.4.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "dompurify": "3.3.3",
    "socket.io-parser": "4.2.6"
  }
}
