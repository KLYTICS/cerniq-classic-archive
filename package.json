{
  "name": "cerniq",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "rm -f frontend/.next/lock && cd frontend && npm run build",
    "lint:backend": "cd backend-node && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "test:backend": "cd backend-node && npm run test -- --forceExit",
    "test:frontend": "cd frontend && npx vitest run"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next": "16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "lint-staged": {
    "backend-node/src/**/*.ts": [
      "bash -c 'cd backend-node && npx eslint --fix --no-warn-ignored \"$@\"' --"
    ],
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --fix --no-warn-ignored \"$@\"' --"
    ]
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1"
  }
}
