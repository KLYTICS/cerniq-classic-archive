{
  "name": "cerniq",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "rm -f frontend/.next/lock && cd frontend && npm run build",
    "deploy:prepare": "rm -rf .vercel/output frontend/.next frontend/playwright-report frontend/test-results",
    "verify:clean": "bash scripts/verify-clean-worktree.sh",
    "verify:apple": "bash scripts/apple/verify.sh",
    "archive:apple": "bash scripts/apple/archive.sh",
    "lint:backend": "cd backend-node && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "test:backend": "cd backend-node && npm run test",
    "test:frontend": "cd frontend && npx vitest run",
    "verify:frontend": "cd frontend && npm run lint && npm run test && npm run test:coverage && npm run build && cd .. && npm run verify:clean",
    "verify:backend": "cd backend-node && npm run lint && npx prisma validate && npm run test && npm run test:cov && npm run build && cd .. && npm run verify:clean",
    "verify:local:critical": "npm run smoke:pre-deploy && npm run deploy:prepare && npm run verify:frontend && npm run verify:backend && cd frontend && npm run test:e2e:critical && cd .. && npm run verify:clean",
    "cerniq:status": "node scripts/cerniq-status.mjs",
    "cerniq:cross": "node scripts/cerniq-cross.mjs",
    "session:register": "node scripts/session/register.mjs",
    "session:claim": "node scripts/session/claim.mjs",
    "session:release": "node scripts/session/release.mjs",
    "session:list": "node scripts/session/list.mjs",
    "session:status": "node scripts/session/status.mjs",
    "session:handoff": "node scripts/session/handoff.mjs",
    "session:doctor": "node scripts/session/doctor.mjs",
    "session:doctor:self-test": "node scripts/session/doctor.mjs --self-test",
    "test:session": "node --test scripts/session/_lib.test.mjs",
    "audit:klytics": "node scripts/audit-klytics.mjs",
    "audit:klytics:summary": "node scripts/audit-klytics.mjs --summary",
    "audit:klytics:self-test": "node scripts/audit-klytics.mjs --self-test",
    "smoke:exports": "cd backend-node && npx ts-node scripts/test-file-exports.ts",
    "smoke:preview": "node scripts/run-preview-smoke.mjs",
    "smoke:pre-deploy": "bash scripts/pre-deploy-smoke.sh",
    "smoke:pre-deploy:test": "bash scripts/pre-deploy-smoke.sh --self-test",
    "smoke:production": "curl -fsS https://cerniq.io >/dev/null && curl -fsS https://cerniq.io/login >/dev/null && curl -fsS https://cerniq.io/pricing >/dev/null && curl -fsS https://cerniq.io/get-started >/dev/null && curl -fsS https://cerniq.io/dashboard >/dev/null && curl -fsS https://api.cerniq.io/health >/dev/null && cd frontend && npm run test:e2e:production",
    "swarm:boot": "node scripts/swarm/boot.mjs",
    "swarm:dispatch": "node scripts/swarm/dispatch.mjs",
    "swarm:gate": "node scripts/swarm/gate.mjs",
    "swarm:health": "node scripts/swarm/health.mjs",
    "swarm:escalate": "node scripts/swarm/escalate.mjs",
    "swarm:fleet": "node scripts/swarm/fleet.mjs",
    "swarm:metrics": "node scripts/swarm/metrics.mjs",
    "swarm:doctor": "node scripts/swarm/doctor.mjs",
    "swarm:orient": "node scripts/swarm/orient.mjs",
    "swarm:handoff": "node scripts/swarm/handoff.mjs",
    "swarm:landing": "node scripts/swarm/landing.mjs",
    "swarm:cross": "node scripts/swarm/cross.mjs",
    "approval": "node scripts/swarm/approval.mjs",
    "approval:auto": "node scripts/swarm/approval-auto.mjs",
    "audit": "node scripts/swarm/audit.mjs",
    "scope:check": "node scripts/swarm/scope-check.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "lint-staged": {
    "backend-node/src/**/*.ts": [
      "bash -c 'cd backend-node && npx eslint --fix --no-warn-ignored \"$@\"' --"
    ],
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --fix --no-warn-ignored \"$@\"' --"
    ]
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1"
  }
}
