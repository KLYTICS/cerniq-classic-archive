# ═══════════════════════════════════════════════════════════════
# CERNIQ Production Environment — Copy to .env.production
# ═══════════════════════════════════════════════════════════════

# ─── CRITICAL (app won't start without these) ─────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cerniq?sslmode=require
JWT_SECRET=                        # min 32 chars, cryptographically random

# ─── Auth (Supabase) ──────────────────────────────────────────
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=https://YOUR_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://YOUR_REF.supabase.co/auth/v1

# ─── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=https://cerniq.io
NEXT_PUBLIC_NODE_API_URL=https://api.cerniq.io
NEXT_PUBLIC_APP_URL=https://cerniq.io
GOOGLE_CALLBACK_URL=https://api.cerniq.io/api/auth/google/callback
GITHUB_CALLBACK_URL=https://api.cerniq.io/api/auth/github/callback

# ─── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ONE_TIME=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_PARTNER=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
ERWIN_EMAIL=eskiessalfonso@gmail.com

# ─── Observability (Sentry + Slack) ──────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
SLACK_WEBHOOK_URL=

# ─── Storage (Cloudflare R2) ──────────────────────────────────
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cerniq-reports

# ─── Security ─────────────────────────────────────────────────
ADMIN_KEY=                         # random, min 32 chars — `openssl rand -hex 32`
MASTER_ACCOUNT_PASSWORD=           # required for data.ai.kiess@gmail.com
# AES-256-GCM key for report_jobs.raw_data at-rest encryption (DPA requirement).
# 64 hex chars = 256 bits. Generate: `openssl rand -hex 32`
# If unset, the service logs a warning and stores data UNENCRYPTED (dev/staging
# only — production DPA compliance requires this to be set).
DATA_ENCRYPTION_KEY=
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.cerniq.io
PLATFORM_RECOVERY_OWNER_BYPASS=true
ALLOWED_ORIGINS=https://cerniq.io
ALLOW_PREVIEW_ORIGINS=false
HEALTH_DETAILS_PUBLIC=false
ALLOW_DEMO_MOCKS=false

# ─── Performance ──────────────────────────────────────────────
DATABASE_POOL_SIZE=20
REDIS_POOL_SIZE=10
NODE_ENV=production

# ─── OAuth (optional) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── AI (REQUIRED in production for the agent runtime) ──────
# NOTE: env.schema.ts rejects production boot if ANTHROPIC_API_KEY
# is missing — the agent runtime (Risk Monitor, CFO Copilot, ALM
# Decision, etc.) will not function without it. Set this in Railway
# or boot will fail.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=                            # REQUIRED
# Optional opt-in Anthropic beta features. Forwarded verbatim as the
# `anthropic-beta` header on every request.
# ANTHROPIC_BETA_HEADER=prompt-caching-2024-07-31

# ─── Agent runtime (Wave-03) ──────────────────────────────────
# Per-run wall-clock deadline. Default 300_000 (5 min) matches
# Vercel Fluid Compute default. Cancels in-flight tool + LLM calls.
AGENT_RUN_TIMEOUT_MS=300000
# Worker concurrency cap. Range [1,50]. Defaults to 5.
AGENT_WORKER_CONCURRENCY=5
# Per-run output token cap. Default 4096 when unset.
MAX_AGENT_TOKENS=8192
# Kill switch for AgentSchedulerService (daily/weekly/monthly cron).
# Canonical values only: 'true' | 'false' | '1' | '0'. Unset = enabled.
# AGENT_SCHEDULER_DISABLED=false
# SSE keepalive interval for the tenant-stream endpoint.
SSE_HEARTBEAT_INTERVAL_MS=30000
# Regulator-grade retention for agent_audit_logs + audit_logs.
# 2555 days = 7 years (matches security page claim).
AUDIT_LOG_RETENTION_DAYS=2555

# ─── Cost circuit breaker ─────────────────────────────────────
# Budget cap per institution (integer cents OR USD). Cents wins
# when both set. LLM_COST_CAP_USD_CENTS=10000 == LLM_COST_ALERT_THRESHOLD_USD=100.
# If unset, the breaker defaults to a $100/month cap per institution.
LLM_COST_ALERT_THRESHOLD_USD=100
# LLM_COST_CAP_USD_CENTS=10000
# Token-pricing overrides. Defaults match public Anthropic list
# price for claude-opus-4-6 ($15 input / $75 output per 1M tokens).
# Set to your negotiated enterprise rate once live.
# LLM_INPUT_USD_PER_MILLION_TOKENS=15
# LLM_OUTPUT_USD_PER_MILLION_TOKENS=75

# ─── Cache ────────────────────────────────────────────────────
# TTL for AI response cache entries. Default 3600 (1 hour).
CACHE_AI_TTL_SECONDS=3600

# ─── Redis (if external) ──────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:6379
