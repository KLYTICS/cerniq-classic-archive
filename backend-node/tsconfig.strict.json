{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "src/instrument.ts",
    "src/telemetry.ts",
    "src/main.ts",
    "src/common/**/*.ts",
    "src/auth/**/*.ts",
    "src/security/**/*.ts",
    "src/api-v1/**/*.ts"
  ],
  "exclude": ["**/*.spec.ts", "dist"]
}
