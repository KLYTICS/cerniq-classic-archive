# ============================================================================
# CERNIQ Backend — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL (must match docker-compose.yml)
DATABASE_URL="postgresql://cerniq:dev_password_change_in_prod@localhost:5433/cerniq?schema=public"

# Auth (JWT_SECRET must be ≥ 32 characters — backend exits on startup if not)
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_EXPIRATION=7d

# Admin endpoints (x-admin-key header)
ADMIN_KEY=change_me_admin_key
MASTER_ACCOUNT_PASSWORD=change_me_master_account_password

# ── Core ────────────────────────────────────────────────────────────────────

NODE_ENV=development
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# Redis (port 6380 = docker-compose external mapping)
REDIS_URL=redis://localhost:6380

# ── Stripe (billing — optional in dev) ──────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONE_TIME=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_PARTNER=

# ── OAuth (optional in dev) ─────────────────────────────────────────────────
# Production contract:
# - Google OAuth client type must be "Web application"
# - Authorized JavaScript origins: https://cerniq.io, https://api.cerniq.io
# - Authorized redirect URI: https://api.cerniq.io/api/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# ── Cloud Storage — R2 (optional, for PDF report uploads) ──────────────────

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Email (optional, for transactional email) ──────────────────────────────

RESEND_API_KEY=

# ── AI (optional, for AI advisor features) ──────────────────────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Observability (optional) ────────────────────────────────────────────────

SENTRY_DSN=
SLACK_WEBHOOK_URL=
LOG_LEVEL=info

# ── Legacy/misc (usually not needed in dev) ─────────────────────────────────
# AUTH_ALLOW_LEGACY=false
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.cerniq.io
# FRONTEND_URL=https://cerniq.io
# GOOGLE_CALLBACK_URL=https://api.cerniq.io/api/auth/google/callback
# PLATFORM_RECOVERY_OWNER_BYPASS=true
# ERWIN_EMAIL=
# FRED_API_KEY=
# HEALTH_DETAILS_PUBLIC=true
