# ============================================================================
# CERNIQ Backend — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL (must match docker-compose.yml)
# Dev default matches docker-compose seed credentials.
# Production: replace from secret store — never commit real credentials.
DATABASE_URL="postgresql://cerniq:dev_password_change_in_prod@localhost:5433/cerniq?schema=public"

# Auth (JWT_SECRET must be ≥ 32 characters — backend exits on startup if not)
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_EXPIRATION=7d

# Admin endpoints (x-admin-key header)
ADMIN_KEY=change_me_admin_key
MASTER_ACCOUNT_PASSWORD=change_me_master_account_password

# API key HMAC pepper (REQUIRED — min 32 characters — generate with: openssl rand -hex 32)
API_KEY_PEPPER=change_me_to_a_random_string_at_least_32_chars

# ── Core ────────────────────────────────────────────────────────────────────

NODE_ENV=development
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# Redis (port 6380 = docker-compose external mapping)
REDIS_URL=redis://localhost:6380

# ── Stripe (billing — optional in dev) ──────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONE_TIME=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_PARTNER=

# ── OAuth (optional in dev) ─────────────────────────────────────────────────
# Production contract:
# - Google OAuth client type must be "Web application"
# - Authorized JavaScript origins: https://cerniq.io, https://api.cerniq.io
# - Authorized redirect URI: https://api.cerniq.io/api/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# ── Cloud Storage — R2 (optional, for PDF report uploads) ──────────────────

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Email (optional, for transactional email) ──────────────────────────────

RESEND_API_KEY=

# ── AI (optional, for AI advisor features) ──────────────────────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Agent Execution Layer ───────────────────────────────────────────────────
# Monthly LLM cost cap per institution in cents (default: 10000 = $100)
# Set to 0 to disable the cost circuit breaker
LLM_COST_CAP_USD_CENTS=10000
# Max parallel agent executions (default: 5)
AGENT_WORKER_CONCURRENCY=5
# Set to "true" to disable every cron-driven background job. Recommended for
# dormant/non-customer-facing Micro Supabase projects.
# BACKGROUND_JOBS_DISABLED=true
# Set to "true" to disable the daily/weekly/monthly Risk Monitor cron
# AGENT_SCHEDULER_DISABLED=false

# ── Observability (optional) ────────────────────────────────────────────────

SENTRY_DSN=
SLACK_WEBHOOK_URL=
LOG_LEVEL=info

# ── Data Retention (optional, defaults are production-safe) ─────────────────
# RETENTION_AUDIT_LOGS_DAYS=2555       # 7 years — matches security page claim
# RETENTION_DEMO_REQUESTS_DAYS=90
# RETENTION_ANALYSIS_RUNS_DAYS=180
# RETENTION_INGESTION_LOGS_DAYS=90

# ── Legacy/misc (usually not needed in dev) ─────────────────────────────────
# AUTH_ALLOW_LEGACY=false
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.cerniq.io
# FRONTEND_URL=https://cerniq.io
# GOOGLE_CALLBACK_URL=https://api.cerniq.io/api/auth/google/callback
# PLATFORM_RECOVERY_OWNER_BYPASS=true
# ERWIN_EMAIL=
# FRED_API_KEY=
# HEALTH_DETAILS_PUBLIC=true

# ── Wave 03: AI Advisor (W3-1) ─────────────────────────────────────────────
# AI_ADVISOR_MODEL=claude-sonnet-4-6  # default, can override to claude-opus-4-6
# ANTHROPIC_API_KEY=                   # required for AI Advisor

# ── Wave 03: Real-Time ALM (W3-5) ──────────────────────────────────────────
# FRED_API_KEY=                        # FRED API key for SOFR/Treasury data
# ALM_REALTIME_POLL_MS=300000          # 5-minute default polling interval

# ── Wave 03: AI Response Caching (TD-005) ──────────────────────────────────
# CACHE_AI_TTL_SECONDS=3600            # 1-hour default TTL for AI responses
