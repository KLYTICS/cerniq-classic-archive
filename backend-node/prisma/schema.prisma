// ============================================================================
// Close Cockpit — month-end financial close workflow
// ----------------------------------------------------------------------------
// One CloseCycle per (org, period). Owns Tasks, JournalEntries, Reconciliations
// and a FluxNarrative. Bilingual EN/ES so PR cooperativa controllers and their
// COSSEC examiners read the same artifacts.
// ============================================================================

model CloseCycle {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  periodYear     Int              @map("period_year")
  periodMonth    Int              @map("period_month") // 1-12
  status         CloseCycleStatus @default(OPEN)
  openedAt       DateTime         @default(now()) @map("opened_at")
  targetCloseAt  DateTime?        @map("target_close_at")
  closedAt       DateTime?        @map("closed_at")
  closedById     String?          @map("closed_by_id") @db.Uuid
  // Materiality snapshot at the moment the cycle was opened — frozen so flux
  // analysis stays reproducible even if the policy is later changed.
  materialityAbs Decimal          @map("materiality_abs") @db.Decimal(14, 2)
  materialityPct Float            @map("materiality_pct")
  notesEn        String?          @map("notes_en")
  notesEs        String?          @map("notes_es")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks            CloseTask[]
  journalEntries   CloseJournalEntry[]
  reconciliations  CloseReconciliation[]
  fluxNarratives   CloseFluxNarrative[]
  activities       CloseActivity[]

  @@unique([organizationId, periodYear, periodMonth])
  @@index([organizationId, status])
  @@index([targetCloseAt])
  @@map("close_cycles")
}

enum CloseCycleStatus {
  OPEN          // pre-close work in progress
  IN_REVIEW     // tie-outs done, controller reviewing
  SIGNED_OFF    // CFO signed off, period locked
  REOPENED      // reopened after sign-off (audit-tracked)
}

model CloseTask {
  id            String          @id @default(uuid()) @db.Uuid
  cycleId       String          @map("cycle_id") @db.Uuid
  // Stable kind key (e.g. "bank_rec_operating", "ap_subledger_tie")
  // so we can build a recurring monthly template per org without coupling
  // to a free-form title.
  kind          String
  titleEn       String          @map("title_en")
  titleEs       String          @map("title_es")
  ownerId       String?         @map("owner_id") @db.Uuid
  dueAt         DateTime?       @map("due_at")
  status        CloseTaskStatus @default(PENDING)
  // Encoded as task ids that must be completed before this one is workable.
  blockedByIds  String[]        @default([]) @map("blocked_by_ids")
  evidenceUrls  String[]        @default([]) @map("evidence_urls")
  completedAt   DateTime?       @map("completed_at")
  completedById String?         @map("completed_by_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  cycle CloseCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId, status])
  @@index([ownerId])
  @@index([dueAt])
  @@map("close_tasks")
}

enum CloseTaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  WAIVED
}

model CloseJournalEntry {
  id           String              @id @default(uuid()) @db.Uuid
  cycleId      String              @map("cycle_id") @db.Uuid
  reference    String              // human ref e.g. "JE-2026-04-001"
  memoEn       String              @map("memo_en")
  memoEs       String              @map("memo_es")
  // Two-sided JE stored as a JSON array of {account, debit, credit, dimension?}
  lines        Json
  // Cached totals so the SUM(debit)==SUM(credit) constraint is enforced in
  // the service layer and we can still query "unbalanced" entries fast.
  totalDebit   Decimal             @map("total_debit")  @db.Decimal(14, 2)
  totalCredit  Decimal             @map("total_credit") @db.Decimal(14, 2)
  status       JournalEntryStatus  @default(DRAFT)
  postedAt     DateTime?           @map("posted_at")
  postedById   String?             @map("posted_by_id") @db.Uuid
  approvedById String?             @map("approved_by_id") @db.Uuid
  evidenceUrls String[]            @default([]) @map("evidence_urls")
  // Self-relation: links a reversal JE to the original it reverses. The
  // original is marked status=REVERSED; the new offsetting JE has its
  // status=POSTED with reversesJeId pointing back. Real ledgers never
  // edit posted entries — they post a reversal. Same pattern here.
  reversesJeId String?             @map("reverses_je_id") @db.Uuid
  reverses     CloseJournalEntry?  @relation("JeReversal", fields: [reversesJeId], references: [id])
  reversedBy   CloseJournalEntry[] @relation("JeReversal")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  cycle CloseCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, reference])
  @@index([cycleId, status])
  @@index([reversesJeId])
  @@map("close_journal_entries")
}

enum JournalEntryStatus {
  DRAFT
  AWAITING_REVIEW
  APPROVED
  POSTED
  REVERSED
}

model CloseReconciliation {
  id              String                @id @default(uuid()) @db.Uuid
  cycleId         String                @map("cycle_id") @db.Uuid
  // GL account being reconciled e.g. "1010 — Operating Cash"
  account         String
  reconType       ReconciliationType    @map("recon_type")
  glBalance       Decimal               @map("gl_balance")        @db.Decimal(14, 2)
  externalBalance Decimal               @map("external_balance")  @db.Decimal(14, 2)
  difference      Decimal               @db.Decimal(14, 2)
  // Items the engine could not auto-match — JSON array of {description, amount, side}
  unmatchedItems  Json                  @default("[]") @map("unmatched_items")
  status          ReconciliationStatus  @default(OPEN)
  preparedById    String?               @map("prepared_by_id") @db.Uuid
  reviewedById    String?               @map("reviewed_by_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  cycle CloseCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId, status])
  @@map("close_reconciliations")
}

enum ReconciliationType {
  BANK
  AP_SUBLEDGER
  AR_SUBLEDGER
  INTERCOMPANY
  PREPAID
  ACCRUAL
  FIXED_ASSET
}

enum ReconciliationStatus {
  OPEN
  TIE
  EXCEPTION
  REVIEWED
  SIGNED_OFF
}

model CloseFluxNarrative {
  id            String   @id @default(uuid()) @db.Uuid
  cycleId       String   @map("cycle_id") @db.Uuid
  account       String
  priorBalance  Decimal  @map("prior_balance")  @db.Decimal(14, 2)
  currentBalance Decimal @map("current_balance") @db.Decimal(14, 2)
  varianceAbs   Decimal  @map("variance_abs")   @db.Decimal(14, 2)
  variancePct   Float    @map("variance_pct")
  isMaterial    Boolean  @map("is_material")
  narrativeEn   String   @map("narrative_en")
  narrativeEs   String   @map("narrative_es")
  // Confidence the narrator has in its own explanation (0..1). Surfaces in UI
  // so reviewers know which narratives need a human pass.
  confidence    Float
  generatedAt   DateTime @default(now()) @map("generated_at")

  cycle CloseCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId, isMaterial])
  @@map("close_flux_narratives")
}

// ============================================================================
// Close Cockpit — activity stream
// ----------------------------------------------------------------------------
// One row per mutation inside the cockpit. Written from inside the same
// transaction as the mutation so the activity log can never drift from the
// state it describes. Feeds the recent-activity strip at the top of the
// cycle workspace and the audit binder's change history section.
// ============================================================================

model CloseActivity {
  id         String             @id @default(uuid()) @db.Uuid
  cycleId    String             @map("cycle_id") @db.Uuid
  actorId    String?            @map("actor_id") @db.Uuid
  kind       CloseActivityKind
  /// Free-form, denormalized summary. English — the strip shows this verbatim
  /// and translates icons, not prose.
  summaryEn  String             @map("summary_en")
  summaryEs  String             @map("summary_es")
  /// JSON payload for structured querying later (taskId, reconId, je ref, …).
  payload    Json               @default("{}")
  createdAt  DateTime           @default(now()) @map("created_at")

  cycle CloseCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId, createdAt])
  @@map("close_activities")
}

enum CloseActivityKind {
  CYCLE_OPENED
  CYCLE_SIGNED_OFF
  CYCLE_REOPENED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_WAIVED
  TASK_CASCADED_UNBLOCK
  TIE_OUT_RUN
  JE_POSTED
  JE_REVERSED
  FLUX_REFRESHED
  GL_UPLOADED
  RECON_REVIEWED
}

// ============================================================================
// Close Cockpit — GL balance snapshots
// ----------------------------------------------------------------------------
// Org-scoped monthly balance snapshots uploaded via CSV or synced from an
// accounting system. Primary source for the Close Cockpit tie-out / flux
// "Pull from GL" / "Load from GL" flows. Replaces the legacy ALM bridge
// that required a user to own both an Organization and a Workspace.
//
// Upsert key is (organizationId, account, periodYear, periodMonth) so
// re-uploading the same file idempotently refreshes the balances without
// creating duplicates. `uploadedAt` captures the most recent write.
// ============================================================================

model GlBalanceSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  account        String
  periodYear     Int      @map("period_year")
  periodMonth    Int      @map("period_month") // 1..12
  balance        Decimal  @db.Decimal(18, 2)
  /// Freeform tag for provenance — e.g. "netsuite:2026-04-monthly.csv" or "manual".
  sourceLabel    String?  @map("source_label")
  uploadedById   String?  @map("uploaded_by_id") @db.Uuid
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, account, periodYear, periodMonth], name: "org_account_period")
  @@index([organizationId, periodYear, periodMonth])
  @@map("gl_balance_snapshots")
}
