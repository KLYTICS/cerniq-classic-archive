model ReportJob {
  id                  String          @id @default(cuid())
  userId              String          @map("user_id") @db.Uuid
  institutionId       String?         @map("institution_id")
  institutionName     String          @map("institution_name")
  status              ReportJobStatus @default(AWAITING_DATA)
  analysisPeriod      String?         @map("analysis_period")   // e.g. "Q1-2026", "Annual-2026"
  previousJobId       String?         @map("previous_job_id")   // links to prior period job for trend tracking
  submittedAt         DateTime?       @map("submitted_at")
  processingStartedAt DateTime?       @map("processing_started_at")
  completedAt         DateTime?       @map("completed_at")
  reportUrl           String?         @map("report_url")
  reportUrlEn         String?         @map("report_url_en")
  reportLang          String          @default("es") @map("report_lang")
  rawData             String?         @map("raw_data")       // AES-256-GCM encrypted CSV snapshot; nulled 90 days after completion
  rawDataPurgedAt     DateTime?       @map("raw_data_purged_at")
  errorMessage        String?         @map("error_message")
  retryCount          Int             @default(0) @map("retry_count")
  triggeredBy         String          @default("payment") @map("triggered_by")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@index([institutionId, status])
  @@index([createdAt])
  @@map("report_jobs")
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("magic_links")
}

model EmailSequence {
  id          String    @id @default(cuid())
  userId      String?   @map("user_id") @db.Uuid
  leadId      String?   @map("lead_id")
  sequenceKey String    @map("sequence_key")
  scheduledAt DateTime  @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  cancelled   Boolean   @default(false)
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId, sequenceKey])
  @@index([scheduledAt, cancelled, sentAt])
  @@map("email_sequences")
}

