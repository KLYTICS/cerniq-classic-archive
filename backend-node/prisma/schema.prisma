  phone           String?
  role            String       @default("CFO")
  institutionName String       @map("institution_name")
  institutionType String       @map("institution_type") // cooperativa | credit_union | community_bank | cpa_consultant | other
  message         String?

  // Source tracking
  source          String       @default("landing_page") // landing_page | demo | outreach | referral
  utmSource       String?      @map("utm_source")
  utmCampaign     String?      @map("utm_campaign")
  referredBy      String?      @map("referred_by")

  // Pipeline state
  status          LeadStatus   @default(NEW)
