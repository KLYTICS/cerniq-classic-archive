model ProspectInstitution {
  id              String   @id @default(cuid())
  name            String
  institutionType String   @map("institution_type")
  location        String?
  estimatedAssets Decimal? @map("estimated_assets") @db.Decimal(18, 2)
  publicDataSource String? @map("public_data_source") // cossec | ncua | manual
  publicDataIdentifier String? @map("public_data_identifier") // charter_number for ncua, slug for cossec
  outreachStatus  String   @default("not_started") @map("outreach_status") // not_started | sample_generated | portal_provisioned | sent | replied | meeting_set | closed
  contactName     String?  @map("contact_name")
  contactEmail    String?  @map("contact_email")
  contactRole     String?  @map("contact_role")
  notes           String?
  reportUrl       String?  @map("report_url")
  intelligenceAccountId String? @map("intelligence_account_id")

  // Demo portal provisioning (cerniq.io/portal demo seats)
  demoUserId         String?   @map("demo_user_id") @db.Uuid
  demoReportJobId    String?   @map("demo_report_job_id")
  demoMagicLinkUrl   String?   @map("demo_magic_link_url")
  demoProvisionedAt  DateTime? @map("demo_provisioned_at")
  demoExpiresAt      DateTime? @map("demo_expires_at")
  demoLastViewedAt   DateTime? @map("demo_last_viewed_at")
  // Conversion attribution — set by billing.service.closeConvertedDemoProspect
  // when a demo user runs Stripe checkout. Powers the DemoSeatAnalyticsService
  // funnel metrics + the admin revenue-attribution dashboard. Null when the
  // demo expires without converting.
  demoConvertedAt        DateTime? @map("demo_converted_at")
  demoConvertedAmountUsd Decimal?  @map("demo_converted_amount_usd") @db.Decimal(12, 2)
  demoConvertedToTier    String?   @map("demo_converted_to_tier") // monthly | annual | one_time | partner

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  intelligenceAccount IntelligenceAccount? @relation(fields: [intelligenceAccountId], references: [id], onDelete: SetNull)
  engagementEvents    DemoSeatEngagementEvent[]

  @@index([outreachStatus])
  @@index([intelligenceAccountId])
  @@index([demoUserId])
  @@index([demoExpiresAt])
  @@index([demoConvertedAt])
  @@map("prospect_institutions")
}

/// Per-touchpoint event log for demo seat engagement.
///
/// Populated by DemoSeatEngagementService.recordEvent() — every
/// meaningful action in a demo seat's lifecycle (provisioning, email
/// sends, portal views, report downloads, upgrade clicks, conversion,
/// expiry, reminders) writes a row here. Powers the admin per-seat
/// timeline UI and future cohort / funnel drop-off analytics.
///
/// Append-only: rows are never updated or deleted once written (except
/// via cascading delete when the parent prospect is removed, which is
/// itself an extremely rare operation).
model DemoSeatEngagementEvent {
  id                    String   @id @default(cuid())
  prospectInstitutionId String   @map("prospect_institution_id")
  /// The demo user associated with the seat at the time of the event.
  /// Null for events recorded before a user was provisioned.
  userId                String?  @map("user_id") @db.Uuid
  /// provisioned | email_sent | email_opened | email_clicked |
  /// portal_viewed | report_viewed | alco_downloaded |
  /// upgrade_clicked | converted | expired | reminder_sent
  eventType             String   @map("event_type")
  /// Free-form context: {daysRemaining, language, amountUsd, toTier, ...}
  metadata              Json?
  createdAt             DateTime @default(now()) @map("created_at")

  prospect ProspectInstitution @relation(fields: [prospectInstitutionId], references: [id], onDelete: Cascade)

  @@index([prospectInstitutionId, createdAt])
  @@index([eventType])
  @@index([userId])
  @@map("demo_seat_engagement_events")
}

