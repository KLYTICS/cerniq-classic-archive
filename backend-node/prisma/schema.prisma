generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== SpendCheck Models =====

enum InstitutionRole {
  OWNER
  ANALYST
  VIEWER
}

model User {
  id            String          @id @default(uuid()) @db.Uuid
  email         String          @unique
  name          String?
  avatarUrl     String?         @map("avatar_url")
  passwordHash  String?         @map("password_hash")
  emailVerified Boolean         @default(false) @map("email_verified")
  provider      String          @default("email")
  providerId    String?         @map("provider_id")
  role          InstitutionRole @default(OWNER)
  lastLoginAt   DateTime?       @map("last_login_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  organizationMembers OrganizationMember[]
  expenses            Expense[]
  portfolios          Portfolio[]
  refreshTokens       RefreshToken[]
  apiKeys             ApiKey[]
  workspaces          Workspace[]
  subscription        Subscription?
  reportJobs          ReportJob[]
  magicLinks          MagicLink[]
  partnerConfig       PartnerConfig?
  analysisRuns        AnalysisRun[]
  ingestionLogs       IngestionLog[]
  passwordResetTokens PasswordResetToken[]
  intelligenceRuns    IntelligenceRun[]
  intelligenceActions IntelligenceAction[]
  intelligenceArtifacts IntelligenceArtifact[]
  workspaceMemoryEntries WorkspaceMemoryEntry[]

  @@unique([provider, providerId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id") @db.Uuid
  name      String
  keyPrefix String    @map("key_prefix")
  keyHash   String    @unique @map("key_hash")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt DateTime?  @map("revoked_at")
  expiresAt DateTime?  @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("api_keys")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members            OrganizationMember[]
  expenses           Expense[]
  closeCycles        CloseCycle[]
  glBalanceSnapshots GlBalanceSnapshot[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           MemberRole
  invitedBy      String?  @map("invited_by") @db.Uuid
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum MemberRole {
  ADMIN
  MEMBER
  VIEWER
}

model Expense {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  merchantName   String        @map("merchant_name")
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  category       String?
  description    String?
  transactionDate DateTime     @map("transaction_date")
  receiptUrl     String?       @map("receipt_url")
  status         ExpenseStatus @default(DRAFT)
  aiExtracted    Boolean       @default(false) @map("ai_extracted")
  aiConfidence   Float?        @map("ai_confidence")
  aiData         Json?         @map("ai_data")
  invoiceHash    String?       @map("invoice_hash")
  anomalyFlags   String[]      @default([]) @map("anomaly_flags")
  riskScore      Int           @default(0) @map("risk_score")
  reviewStatus   String        @default("PENDING") @map("review_status")
  approvedBy     String?       @map("approved_by") @db.Uuid
  approvedAt     DateTime?     @map("approved_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([invoiceHash])
  @@index([transactionDate])
  @@index([category])
  @@index([reviewStatus])
  @@map("expenses")
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

// ===== Existing CapexCycle Models =====

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String?  @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  uploads      Upload[]
  invoices     Invoice[]
  findings     Finding[]
  reports      Report[]
  institutions Institution[]
  intelligenceAccounts IntelligenceAccount[]
  intelligenceRuns IntelligenceRun[]
  intelligenceArtifacts IntelligenceArtifact[]
  workspaceMemoryEntries WorkspaceMemoryEntry[]

  @@map("workspaces")
}

// ===== ALM Enterprise Models =====

model Institution {
  id                       String    @id @default(cuid())
  workspaceId              String    @map("workspace_id") @db.Uuid
  name                     String
  type                     String    // bank | credit_union | family_office | cooperativa
  totalAssets              Decimal   @map("total_assets") @db.Decimal(18, 2)
  currency                 String    @default("USD")
  reportingDate            DateTime  @map("reporting_date")
  /// Stable idempotency key for fixture-based seeding. Real-world institutions leave this null.
  /// (workspaceId, seedKey) is unique → seed pipeline can re-run safely between sessions.
  seedKey                  String?   @map("seed_key")
  cossecRegistrationNumber String?   @map("cossec_registration_number")
  fiscalYearEnd            String?   @map("fiscal_year_end")       // "december" | "june" | "march"
  alcoMeetingFrequency     String?   @map("alco_meeting_frequency") // "monthly" | "quarterly"
  alcoNextDate             DateTime? @map("alco_next_date")
  lastExamDate             DateTime? @map("last_exam_date")
  nextExamDate             DateTime? @map("next_exam_date")
  primaryRegulator         String    @default("COSSEC") @map("primary_regulator")
  contactName              String?   @map("contact_name")
  contactEmail             String?   @map("contact_email")
  contactPhone             String?   @map("contact_phone")
  preferredLanguage        String    @default("es") @map("preferred_language") // "es" | "en" | "both"
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  balanceSheetItems     BalanceSheetItem[]
  interestRateScenarios InterestRateScenario[]
  liquidityPositions    LiquidityPosition[]
  analysisRuns          AnalysisRun[]
  ingestionLogs         IngestionLog[]
  savedScenarios        SavedScenario[]
  yieldCurves           YieldCurve[]
  loanSegments          LoanSegment[]
  depositTiers          DepositTier[]
  concentrationLimits   ConcentrationLimit[]
  loanCohorts           LoanCohort[]
  ceclVintageAllowances CeclVintageAllowance[]
  irrPolicyLimits       IRRPolicyLimit[]
  policyBreachLogs      PolicyBreachLog[]
  columnMappingMemories ColumnMappingMemory[]
  boardReports          BoardReport[]
  webhookSubscriptions  WebhookSubscription[]
  ssoConfiguration      SSOConfiguration?
  institutionAlerts     InstitutionAlert[]

  @@unique([workspaceId, seedKey], name: "workspace_seed_key")
  @@index([workspaceId])
  @@index([type])
  @@map("institutions")
}

model BalanceSheetItem {
  id            String    @id @default(cuid())
  institutionId String    @map("institution_id")
  category      String    // asset | liability
  subcategory   String    // loans | securities | deposits | borrowings | equity | cash
  name          String
  balance       Decimal   @db.Decimal(18, 2) // in millions
  rate          Decimal   @db.Decimal(8, 6) // current yield/cost as decimal (0.055 = 5.5%)
  duration      Decimal   @db.Decimal(8, 4) // Macaulay duration in years
  repriceDate   DateTime? @map("reprice_date")
  maturityDate  DateTime? @map("maturity_date")
  rateType      String    @map("rate_type") // fixed | variable | hybrid
  depositBeta   Decimal?  @map("deposit_beta") @db.Decimal(8, 6) // pass-through rate (0.0-1.0) for deposit beta calibration
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("balance_sheet_items")
}

model InterestRateScenario {
  id            String   @id @default(cuid())
  institutionId String   @map("institution_id")
  name          String
  shiftBps      Int      @map("shift_bps")
  niImpact      Decimal  @map("ni_impact") @db.Decimal(18, 2)
  mveImpact     Decimal  @map("mve_impact") @db.Decimal(18, 2)
  duration      Decimal  @db.Decimal(8, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("interest_rate_scenarios")
}

model LiquidityPosition {
  id            String   @id @default(cuid())
  institutionId String   @map("institution_id")
  date          DateTime
  hqlaLevel1    Decimal  @map("hqla_level1") @db.Decimal(18, 2)
  hqlaLevel2    Decimal  @map("hqla_level2") @db.Decimal(18, 2)
  cashOutflows  Decimal  @map("cash_outflows") @db.Decimal(18, 2)
  cashInflows   Decimal  @map("cash_inflows") @db.Decimal(18, 2)
  lcr           Decimal  @db.Decimal(10, 6)
  nsfr          Decimal  @db.Decimal(10, 6)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@unique([institutionId, date])
  @@map("liquidity_positions")
}

// ===== Quant Powerhouse Models =====

model SavedScenario {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  createdBy       String   @map("created_by") // userId
  name            String
  description     String?
  scenarioType    String   @map("scenario_type") // custom | parallel | steepening | flattening | pr_specific | hurricane | recession
  parameters      Json     // ScenarioParams: rateShockBps, depositRunoffPct, etc.
  results         Json?    // ScenarioResult: nimImpact, lcrBefore/After, verdict, etc.
  tags            String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, createdAt])
  @@index([createdBy])
  @@map("saved_scenarios")
}

model YieldCurve {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  name            String
  asOfDate        DateTime @map("as_of_date")
  tenors          Json     // Array of { tenor: number, rate: number } e.g., [{ tenor: 0.25, rate: 0.045 }, ...]
  source          String   @default("manual") // manual | fed_h15 | interpolated
  isBase          Boolean  @default(false) @map("is_base") // marks the institution's current base curve
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, asOfDate])
  @@map("yield_curves")
}

model LoanSegment {
  id                  String   @id @default(cuid())
  institutionId       String   @map("institution_id")
  segmentName         String   @map("segment_name") // e.g., "Auto Loans", "Commercial RE", "Consumer Unsecured"
  balance             Decimal  @db.Decimal(18, 2) // outstanding balance in millions
  weightedAvgRate     Decimal  @map("weighted_avg_rate") @db.Decimal(8, 6) // decimal (0.065 = 6.5%)
  weightedAvgMaturity Decimal  @map("weighted_avg_maturity") @db.Decimal(8, 4) // years
  historicalLossRate  Decimal  @map("historical_loss_rate") @db.Decimal(8, 6) // annualized (0.012 = 1.2%)
  lgd                 Decimal  @default(0.5) @db.Decimal(8, 6) // loss given default (0.0-1.0)
  qualitativeAdj      Decimal  @default(0) @map("qualitative_adj") @db.Decimal(8, 6) // +/- adjustment to loss rate
  asOfDate            DateTime @map("as_of_date")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, asOfDate])
  @@map("loan_segments")
}

model DepositTier {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  tierName        String   @map("tier_name") // insured_core | uninsured | brokered | large_single
  balance         Decimal  @db.Decimal(18, 2) // in millions
  insuredPct      Decimal  @map("insured_pct") @db.Decimal(8, 6) // 0.0-1.0
  flightRate      Decimal  @map("flight_rate") @db.Decimal(8, 6) // monthly runoff rate under stress (0.0-1.0)
  avgRate         Decimal  @map("avg_rate") @db.Decimal(8, 6) // current cost as decimal
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("deposit_tiers")
}

model ConcentrationLimit {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  limitType       String   @map("limit_type") // sector | single_name | geography | product
  limitName       String   @map("limit_name") // e.g., "Commercial RE", "Top 10 Borrowers"
  maxPct          Decimal  @map("max_pct") @db.Decimal(8, 6) // policy limit as decimal (0.25 = 25%)
  currentPct      Decimal  @map("current_pct") @db.Decimal(8, 6) // actual exposure as decimal
  currentBalance  Decimal? @map("current_balance") @db.Decimal(18, 2) // actual $ exposure in millions
  status          String   @default("compliant") // compliant | warning | breach
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("concentration_limits")
}

// ===== Phase IV: ALM Intelligence Expansion Models =====

model LoanCohort {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  loanType        String   @map("loan_type") // residential_mortgage | auto | consumer | commercial
  originationQtr  String   @map("origination_qtr") // "2022Q3"
  originalBalance Decimal  @map("original_balance") @db.Decimal(18, 2)
  currentBalance  Decimal  @map("current_balance") @db.Decimal(18, 2)
  defaults        Decimal  @db.Decimal(18, 2) // cumulative defaults to date
  ageMonths       Int      @map("age_months")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([loanType])
  @@map("loan_cohorts")
}

model CeclVintageAllowance {
  id                String   @id @default(cuid())
  institutionId     String   @map("institution_id")
  runAt             DateTime @default(now()) @map("run_at")
  methodology       String   // "vintage" | "warm" | "pdlgd"
  baseAllowance     Decimal  @map("base_allowance") @db.Decimal(18, 2)
  adverseAllowance  Decimal  @map("adverse_allowance") @db.Decimal(18, 2)
  severeAllowance   Decimal  @map("severe_allowance") @db.Decimal(18, 2)
  segmentBreakdown  Json     @map("segment_breakdown")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("cecl_vintage_allowances")
}

model IRRPolicyLimit {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  limitType      String   @map("limit_type") // EVE_PCT | NII_AT_RISK | DURATION_GAP | REPRICING_GAP
  scenario       String   // "+200bps" | "-100bps" | "base"
  watchPct       Decimal  @map("watch_pct") @db.Decimal(8, 6) // e.g. 15.0
  warningPct     Decimal  @map("warning_pct") @db.Decimal(8, 6) // e.g. 18.0
  breachPct      Decimal  @map("breach_pct") @db.Decimal(8, 6) // e.g. 20.0
  regulatoryRef  String   @map("regulatory_ref") // "OCIF CC-2022-03 §IV.B"
  updatedAt      DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("irr_policy_limits")
}

model PolicyBreachLog {
  id             String    @id @default(cuid())
  institutionId  String    @map("institution_id")
  limitType      String    @map("limit_type")
  breachLevel    String    @map("breach_level") // WATCH | WARNING | BREACH
  actualValue    Decimal   @map("actual_value") @db.Decimal(18, 6)
  limitValue     Decimal   @map("limit_value") @db.Decimal(18, 6)
  detectedAt     DateTime  @default(now()) @map("detected_at")
  resolvedAt     DateTime? @map("resolved_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, detectedAt])
  @@map("policy_breach_logs")
}

model ColumnMappingMemory {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  csvColumnName  String   @map("csv_column_name")
  cerniqField    String   @map("cerniq_field")
  confirmedAt    DateTime @default(now()) @map("confirmed_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, csvColumnName])
  @@map("column_mapping_memories")
}

model BoardReport {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  reportMonth    String   @map("report_month") // "2025-06"
  generatedAt    DateTime @default(now()) @map("generated_at")
  pdfUrl         String?  @map("pdf_url")
  emailsSent     Int      @default(0) @map("emails_sent")
  camelComposite Decimal? @map("camel_composite") @db.Decimal(6, 2)
  nimSnapshot    Decimal? @map("nim_snapshot") @db.Decimal(10, 6)
  lcrSnapshot    Decimal? @map("lcr_snapshot") @db.Decimal(10, 6)
  topRiskAlert   String?  @map("top_risk_alert")
  updatedAt      DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([reportMonth])
  @@unique([institutionId, reportMonth])
  @@map("board_reports")
}

model Upload {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  fileName    String    @map("file_name")
  fileType    String    @map("file_type")
  fileUrl     String?   @map("file_url")
  status      String    @default("pending") // pending, processing, completed, error
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([workspaceId])
  @@map("uploads")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  uploadId      String?  @map("upload_id") @db.Uuid
  vendorName    String   @map("vendor_name")
  invoiceNumber String?  @map("invoice_number")
  invoiceDate   DateTime? @map("invoice_date")
  amount        Decimal  @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  upload    Upload?   @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  findings  Finding[]

  @@map("invoices")
}

model Finding {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  invoiceId   String?  @map("invoice_id") @db.Uuid
  vendorName  String   @map("vendor_name")
  issueType   String   @map("issue_type") // duplicate, subscription, price_drift
  severity    String   // high, medium, low
  amount      Decimal? @db.Decimal(12, 2)
  description String
  status      String   @default("open") // open, dismissed, resolved
  confidence  String   @default("high")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@map("findings")
}

model Report {
  id        String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  title       String
  summary     Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("reports")
}

// ===== Market Data Models =====

model Ticker {
  ticker      String   @id
  name        String
  sector      String
  industry    String?
  assetType   String   @map("asset_type") // stock, crypto, etf, future
  exchange    String?
  country     String?
  marketCap   Decimal? @map("market_cap") @db.Decimal(18, 2)
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json?
  firstAdded  DateTime @default(now()) @map("first_added") @db.Timestamptz(6)
  lastUpdated DateTime @updatedAt @map("last_updated") @db.Timestamptz(6)

  positions Position[]

  @@map("tickers")
}

// ===== Portfolio Models =====

model Portfolio {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  currency    String   @default("USD")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]

  @@index([userId])
  @@map("portfolios")
}

