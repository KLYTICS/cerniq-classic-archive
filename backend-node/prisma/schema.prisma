generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== SpendCheck Models =====

enum InstitutionRole {
  OWNER
  ANALYST
  VIEWER
}

model User {
  id            String          @id @default(uuid()) @db.Uuid
  email         String          @unique
  name          String?
  avatarUrl     String?         @map("avatar_url")
  passwordHash  String?         @map("password_hash")
  emailVerified Boolean         @default(false) @map("email_verified")
  provider      String          @default("email")
  providerId    String?         @map("provider_id")
  role          InstitutionRole @default(OWNER)
  lastLoginAt   DateTime?       @map("last_login_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  organizationMembers OrganizationMember[]
  expenses            Expense[]
  portfolios          Portfolio[]
  refreshTokens       RefreshToken[]
  apiKeys             ApiKey[]
  workspaces          Workspace[]
  subscription        Subscription?
  reportJobs          ReportJob[]
  magicLinks          MagicLink[]
  partnerConfig       PartnerConfig?
  analysisRuns        AnalysisRun[]
  ingestionLogs       IngestionLog[]
  passwordResetTokens PasswordResetToken[]

  @@unique([provider, providerId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id") @db.Uuid
  name      String
  keyPrefix String    @map("key_prefix")
  keyHash   String    @unique @map("key_hash")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt DateTime?  @map("revoked_at")
  expiresAt DateTime?  @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("api_keys")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members  OrganizationMember[]
  expenses Expense[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           MemberRole
  invitedBy      String?  @map("invited_by") @db.Uuid
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum MemberRole {
  ADMIN
  MEMBER
  VIEWER
}

model Expense {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  merchantName   String        @map("merchant_name")
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  category       String?
  description    String?
  transactionDate DateTime     @map("transaction_date")
  receiptUrl     String?       @map("receipt_url")
  status         ExpenseStatus @default(DRAFT)
  aiExtracted    Boolean       @default(false) @map("ai_extracted")
  aiConfidence   Float?        @map("ai_confidence")
  aiData         Json?         @map("ai_data")
  invoiceHash    String?       @map("invoice_hash")
  anomalyFlags   String[]      @default([]) @map("anomaly_flags")
  riskScore      Int           @default(0) @map("risk_score")
  reviewStatus   String        @default("PENDING") @map("review_status")
  approvedBy     String?       @map("approved_by") @db.Uuid
  approvedAt     DateTime?     @map("approved_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([invoiceHash])
  @@index([transactionDate])
  @@index([category])
  @@index([reviewStatus])
  @@map("expenses")
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

// ===== Existing CapexCycle Models =====

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String?  @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  uploads      Upload[]
  invoices     Invoice[]
  findings     Finding[]
  reports      Report[]
  institutions Institution[]

  @@map("workspaces")
}

// ===== ALM Enterprise Models =====

model Institution {
  id                       String    @id @default(cuid())
  workspaceId              String    @map("workspace_id")
  name                     String
  type                     String    // bank | credit_union | family_office | cooperativa
  totalAssets              Decimal   @map("total_assets") @db.Decimal(18, 2)
  currency                 String    @default("USD")
  reportingDate            DateTime  @map("reporting_date")
  cossecRegistrationNumber String?   @map("cossec_registration_number")
  fiscalYearEnd            String?   @map("fiscal_year_end")       // "december" | "june" | "march"
  alcoMeetingFrequency     String?   @map("alco_meeting_frequency") // "monthly" | "quarterly"
  alcoNextDate             DateTime? @map("alco_next_date")
  lastExamDate             DateTime? @map("last_exam_date")
  nextExamDate             DateTime? @map("next_exam_date")
  primaryRegulator         String    @default("COSSEC") @map("primary_regulator")
  contactName              String?   @map("contact_name")
  contactEmail             String?   @map("contact_email")
  contactPhone             String?   @map("contact_phone")
  preferredLanguage        String    @default("es") @map("preferred_language") // "es" | "en" | "both"
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  balanceSheetItems     BalanceSheetItem[]
  interestRateScenarios InterestRateScenario[]
  liquidityPositions    LiquidityPosition[]
  analysisRuns          AnalysisRun[]
  ingestionLogs         IngestionLog[]
  savedScenarios        SavedScenario[]
  yieldCurves           YieldCurve[]
  loanSegments          LoanSegment[]
  depositTiers          DepositTier[]
  concentrationLimits   ConcentrationLimit[]
  loanCohorts           LoanCohort[]
  ceclVintageAllowances CeclVintageAllowance[]
  irrPolicyLimits       IRRPolicyLimit[]
  policyBreachLogs      PolicyBreachLog[]
  columnMappingMemories ColumnMappingMemory[]
  boardReports          BoardReport[]
  webhookSubscriptions  WebhookSubscription[]
  ssoConfiguration      SSOConfiguration?
  institutionAlerts     InstitutionAlert[]

  @@index([workspaceId])
  @@index([type])
  @@map("institutions")
}

model BalanceSheetItem {
  id            String    @id @default(cuid())
  institutionId String    @map("institution_id")
  category      String    // asset | liability
  subcategory   String    // loans | securities | deposits | borrowings | equity | cash
  name          String
  balance       Decimal   @db.Decimal(18, 2) // in millions
  rate          Decimal   @db.Decimal(8, 6) // current yield/cost as decimal (0.055 = 5.5%)
  duration      Decimal   @db.Decimal(8, 4) // Macaulay duration in years
  repriceDate   DateTime? @map("reprice_date")
  maturityDate  DateTime? @map("maturity_date")
  rateType      String    @map("rate_type") // fixed | variable | hybrid
  depositBeta   Decimal?  @map("deposit_beta") @db.Decimal(8, 6) // pass-through rate (0.0-1.0) for deposit beta calibration
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("balance_sheet_items")
}

model InterestRateScenario {
  id            String   @id @default(cuid())
  institutionId String   @map("institution_id")
  name          String
  shiftBps      Int      @map("shift_bps")
  niImpact      Decimal  @map("ni_impact") @db.Decimal(18, 2)
  mveImpact     Decimal  @map("mve_impact") @db.Decimal(18, 2)
  duration      Decimal  @db.Decimal(8, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("interest_rate_scenarios")
}

model LiquidityPosition {
  id            String   @id @default(cuid())
  institutionId String   @map("institution_id")
  date          DateTime
  hqlaLevel1    Decimal  @map("hqla_level1") @db.Decimal(18, 2)
  hqlaLevel2    Decimal  @map("hqla_level2") @db.Decimal(18, 2)
  cashOutflows  Decimal  @map("cash_outflows") @db.Decimal(18, 2)
  cashInflows   Decimal  @map("cash_inflows") @db.Decimal(18, 2)
  lcr           Decimal  @db.Decimal(10, 6)
  nsfr          Decimal  @db.Decimal(10, 6)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("liquidity_positions")
}

// ===== Quant Powerhouse Models =====

model SavedScenario {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  createdBy       String   @map("created_by") // userId
  name            String
  description     String?
  scenarioType    String   @map("scenario_type") // custom | parallel | steepening | flattening | pr_specific | hurricane | recession
  parameters      Json     // ScenarioParams: rateShockBps, depositRunoffPct, etc.
  results         Json?    // ScenarioResult: nimImpact, lcrBefore/After, verdict, etc.
  tags            String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, createdAt])
  @@index([createdBy])
  @@map("saved_scenarios")
}

model YieldCurve {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  name            String
  asOfDate        DateTime @map("as_of_date")
  tenors          Json     // Array of { tenor: number, rate: number } e.g., [{ tenor: 0.25, rate: 0.045 }, ...]
  source          String   @default("manual") // manual | fed_h15 | interpolated
  isBase          Boolean  @default(false) @map("is_base") // marks the institution's current base curve
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, asOfDate])
  @@map("yield_curves")
}

model LoanSegment {
  id                  String   @id @default(cuid())
  institutionId       String   @map("institution_id")
  segmentName         String   @map("segment_name") // e.g., "Auto Loans", "Commercial RE", "Consumer Unsecured"
  balance             Decimal  @db.Decimal(18, 2) // outstanding balance in millions
  weightedAvgRate     Decimal  @map("weighted_avg_rate") @db.Decimal(8, 6) // decimal (0.065 = 6.5%)
  weightedAvgMaturity Decimal  @map("weighted_avg_maturity") @db.Decimal(8, 4) // years
  historicalLossRate  Decimal  @map("historical_loss_rate") @db.Decimal(8, 6) // annualized (0.012 = 1.2%)
  lgd                 Decimal  @default(0.5) @db.Decimal(8, 6) // loss given default (0.0-1.0)
  qualitativeAdj      Decimal  @default(0) @map("qualitative_adj") @db.Decimal(8, 6) // +/- adjustment to loss rate
  asOfDate            DateTime @map("as_of_date")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, asOfDate])
  @@map("loan_segments")
}

model DepositTier {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  tierName        String   @map("tier_name") // insured_core | uninsured | brokered | large_single
  balance         Decimal  @db.Decimal(18, 2) // in millions
  insuredPct      Decimal  @map("insured_pct") @db.Decimal(8, 6) // 0.0-1.0
  flightRate      Decimal  @map("flight_rate") @db.Decimal(8, 6) // monthly runoff rate under stress (0.0-1.0)
  avgRate         Decimal  @map("avg_rate") @db.Decimal(8, 6) // current cost as decimal
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("deposit_tiers")
}

model ConcentrationLimit {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  limitType       String   @map("limit_type") // sector | single_name | geography | product
  limitName       String   @map("limit_name") // e.g., "Commercial RE", "Top 10 Borrowers"
  maxPct          Decimal  @map("max_pct") @db.Decimal(8, 6) // policy limit as decimal (0.25 = 25%)
  currentPct      Decimal  @map("current_pct") @db.Decimal(8, 6) // actual exposure as decimal
  currentBalance  Decimal? @map("current_balance") @db.Decimal(18, 2) // actual $ exposure in millions
  status          String   @default("compliant") // compliant | warning | breach
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("concentration_limits")
}

// ===== Phase IV: ALM Intelligence Expansion Models =====

model LoanCohort {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  loanType        String   @map("loan_type") // residential_mortgage | auto | consumer | commercial
  originationQtr  String   @map("origination_qtr") // "2022Q3"
  originalBalance Decimal  @map("original_balance") @db.Decimal(18, 2)
  currentBalance  Decimal  @map("current_balance") @db.Decimal(18, 2)
  defaults        Decimal  @db.Decimal(18, 2) // cumulative defaults to date
  ageMonths       Int      @map("age_months")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([loanType])
  @@map("loan_cohorts")
}

model CeclVintageAllowance {
  id                String   @id @default(cuid())
  institutionId     String   @map("institution_id")
  runAt             DateTime @default(now()) @map("run_at")
  methodology       String   // "vintage" | "warm" | "pdlgd"
  baseAllowance     Decimal  @map("base_allowance") @db.Decimal(18, 2)
  adverseAllowance  Decimal  @map("adverse_allowance") @db.Decimal(18, 2)
  severeAllowance   Decimal  @map("severe_allowance") @db.Decimal(18, 2)
  segmentBreakdown  Json     @map("segment_breakdown")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("cecl_vintage_allowances")
}

model IRRPolicyLimit {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  limitType      String   @map("limit_type") // EVE_PCT | NII_AT_RISK | DURATION_GAP | REPRICING_GAP
  scenario       String   // "+200bps" | "-100bps" | "base"
  watchPct       Decimal  @map("watch_pct") @db.Decimal(8, 6) // e.g. 15.0
  warningPct     Decimal  @map("warning_pct") @db.Decimal(8, 6) // e.g. 18.0
  breachPct      Decimal  @map("breach_pct") @db.Decimal(8, 6) // e.g. 20.0
  regulatoryRef  String   @map("regulatory_ref") // "OCIF CC-2022-03 §IV.B"
  updatedAt      DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("irr_policy_limits")
}

model PolicyBreachLog {
  id             String    @id @default(cuid())
  institutionId  String    @map("institution_id")
  limitType      String    @map("limit_type")
  breachLevel    String    @map("breach_level") // WATCH | WARNING | BREACH
  actualValue    Decimal   @map("actual_value") @db.Decimal(18, 6)
  limitValue     Decimal   @map("limit_value") @db.Decimal(18, 6)
  detectedAt     DateTime  @default(now()) @map("detected_at")
  resolvedAt     DateTime? @map("resolved_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, detectedAt])
  @@map("policy_breach_logs")
}

model ColumnMappingMemory {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  csvColumnName  String   @map("csv_column_name")
  cerniqField    String   @map("cerniq_field")
  confirmedAt    DateTime @default(now()) @map("confirmed_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, csvColumnName])
  @@map("column_mapping_memories")
}

model BoardReport {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  reportMonth    String   @map("report_month") // "2025-06"
  generatedAt    DateTime @default(now()) @map("generated_at")
  pdfUrl         String?  @map("pdf_url")
  emailsSent     Int      @default(0) @map("emails_sent")
  camelComposite Decimal? @map("camel_composite") @db.Decimal(6, 2)
  nimSnapshot    Decimal? @map("nim_snapshot") @db.Decimal(10, 6)
  lcrSnapshot    Decimal? @map("lcr_snapshot") @db.Decimal(10, 6)
  topRiskAlert   String?  @map("top_risk_alert")
  updatedAt      DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([reportMonth])
  @@map("board_reports")
}

model Upload {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  fileName    String    @map("file_name")
  fileType    String    @map("file_type")
  fileUrl     String?   @map("file_url")
  status      String    @default("pending") // pending, processing, completed, error
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([workspaceId])
  @@map("uploads")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  uploadId      String?  @map("upload_id") @db.Uuid
  vendorName    String   @map("vendor_name")
  invoiceNumber String?  @map("invoice_number")
  invoiceDate   DateTime? @map("invoice_date")
  amount        Decimal  @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  upload    Upload?   @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  findings  Finding[]

  @@map("invoices")
}

model Finding {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  invoiceId   String?  @map("invoice_id") @db.Uuid
  vendorName  String   @map("vendor_name")
  issueType   String   @map("issue_type") // duplicate, subscription, price_drift
  severity    String   // high, medium, low
  amount      Decimal? @db.Decimal(12, 2)
  description String
  status      String   @default("open") // open, dismissed, resolved
  confidence  String   @default("high")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@map("findings")
}

model Report {
  id        String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  title       String
  summary     Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("reports")
}

// ===== Market Data Models =====

model Ticker {
  ticker      String   @id
  name        String
  sector      String
  industry    String?
  assetType   String   @map("asset_type") // stock, crypto, etf, future
  exchange    String?
  country     String?
  marketCap   Decimal? @map("market_cap") @db.Decimal(18, 2)
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json?
  firstAdded  DateTime @default(now()) @map("first_added") @db.Timestamptz(6)
  lastUpdated DateTime @updatedAt @map("last_updated") @db.Timestamptz(6)

  positions Position[]

  @@map("tickers")
}

// ===== Portfolio Models =====

model Portfolio {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  currency    String   @default("USD")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]

  @@index([userId])
  @@map("portfolios")
}

model Position {
  id             String   @id @default(uuid()) @db.Uuid
  portfolioId    String   @map("portfolio_id") @db.Uuid
  ticker         String?
  quantity       Decimal  @db.Decimal(18, 8)
  avgCost        Decimal  @map("avg_cost") @db.Decimal(18, 2)
  addedAt        DateTime @default(now()) @map("added_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Ticker?   @relation(fields: [ticker], references: [ticker], onDelete: SetNull)

  @@index([ticker])
  @@map("positions")
  @@unique([portfolioId, ticker])
}

// ===== Pipeline Models =====

enum PipelineStatus {
  RUNNING
  SUCCESS
  FAILED
}

model PipelineRun {
  id               String         @id @default(uuid()) @db.Uuid
  startedAt        DateTime       @default(now()) @map("started_at")
  completedAt      DateTime?      @map("completed_at")
  status           PipelineStatus @default(RUNNING)
  tickersProcessed Int            @default(0) @map("tickers_processed")
  errors           Json?
  durationMs       Int?           @map("duration_ms")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@index([status])
  @@index([startedAt])
  @@map("pipeline_runs")
}

model MarketPrice {
  id        String   @id @default(uuid()) @db.Uuid
  ticker    String
  date      DateTime @db.Date
  open      Decimal? @db.Decimal(18, 4)
  high      Decimal? @db.Decimal(18, 4)
  low       Decimal? @db.Decimal(18, 4)
  close     Decimal  @db.Decimal(18, 4)
  volume    BigInt?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ticker, date])
  @@index([ticker])
  @@index([date])
  @@map("market_prices")
}

// ===== Demo Request (Landing Page) =====

model DemoRequest {
  id              String   @id @default(uuid()) @db.Uuid
  email           String
  name            String?
  institutionName String?  @map("institution_name")
  institutionType String?  @map("institution_type")
  totalAssets     String?  @map("total_assets")
  message         String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([createdAt])
  @@map("demo_requests")
}

// ===== Lead Pipeline =====

enum LeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  PROPOSAL_SENT
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
  UNQUALIFIED
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

model Lead {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Contact
  name            String
  email           String
  phone           String?
  role            String       @default("CFO")
  institutionName String       @map("institution_name")
  institutionType String       @map("institution_type") // cooperativa | credit_union | community_bank | cpa_consultant | other
  message         String?

  // Source tracking
  source          String       @default("landing_page") // landing_page | demo | outreach | referral
  utmSource       String?      @map("utm_source")
  utmCampaign     String?      @map("utm_campaign")
  referredBy      String?      @map("referred_by")

  // Pipeline state
  status          LeadStatus   @default(NEW)
  priority        LeadPriority @default(MEDIUM)
  assignedTo      String?      @map("assigned_to")
  notes           String?
  nextFollowUp    DateTime?    @map("next_follow_up")

  // Outcome
  convertedAt     DateTime?    @map("converted_at")
  revenueAmount   Decimal?     @map("revenue_amount") @db.Decimal(18, 2)
  dealType        String?      @map("deal_type") // one_time | monthly | partner | enterprise

  // Report job
  reportJobId     String?      @map("report_job_id")
  reportSentAt    DateTime?    @map("report_sent_at")

  // Enrichment
  publicDataSnapshot Json?     @map("public_data_snapshot")

  @@index([status])
  @@index([priority])
  @@index([email])
  @@map("leads")
}

// ===== Prospect Pipeline (Outbound) =====

model ProspectInstitution {
  id              String   @id @default(cuid())
  name            String
  institutionType String   @map("institution_type")
  location        String?
  estimatedAssets Decimal? @map("estimated_assets") @db.Decimal(18, 2)
  publicDataSource String? @map("public_data_source") // cossec | ncua | manual
  outreachStatus  String   @default("not_started") @map("outreach_status") // not_started | sample_generated | sent | replied | meeting_set | closed
  contactName     String?  @map("contact_name")
  contactEmail    String?  @map("contact_email")
  contactRole     String?  @map("contact_role")
  notes           String?
  reportUrl       String?  @map("report_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([outreachStatus])
  @@map("prospect_institutions")
}

// ===== Sector Benchmarks =====

model CooperativaBenchmark {
  id                    String   @id @default(cuid())
  period                String   // Q3 2025
  totalAssetsMedian     Decimal? @map("total_assets_median") @db.Decimal(18, 2)
  capitalRatioMedian    Decimal? @map("capital_ratio_median") @db.Decimal(10, 6)
  loanToShareMedian     Decimal? @map("loan_to_share_median") @db.Decimal(10, 6)
  liquidityRatioMedian  Decimal? @map("liquidity_ratio_median") @db.Decimal(10, 6)
  niiMarginMedian       Decimal? @map("nii_margin_median") @db.Decimal(10, 6)
  assetGrowthYoy        Decimal? @map("asset_growth_yoy") @db.Decimal(10, 6)
  memberCountTotal      Int?     @map("member_count_total")
  activeInstitutions    Int?     @map("active_institutions")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([period])
  @@map("cooperativa_benchmarks")
}

// ===== Micro-SaaS Billing & Pipeline =====

enum SubscriptionTier {
  free
  one_time
  monthly
  annual
  partner
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  grace_period
}

enum AnalysisRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum IngestionLogStatus {
  VALIDATED
  IMPORTED
  FAILED
  DRY_RUN
}

model AnalysisRun {
  id                 String            @id @default(cuid())
  institutionId      String            @map("institution_id")
  createdByUserId    String            @map("created_by_user_id") @db.Uuid
  status             AnalysisRunStatus @default(RUNNING)
  analysisType       String            @default("full_analysis") @map("analysis_type")
  triggeredBy        String            @default("manual") @map("triggered_by")
  modelVersion       String            @default("alm-v1") @map("model_version")
  scenarioSet        String            @default("base_parallel_shocks") @map("scenario_set")
  assumptions        Json?
  parameterSnapshot  Json              @map("parameter_snapshot")
  balanceSheetSnapshot Json            @map("balance_sheet_snapshot")
  resultSummary      Json?             @map("result_summary")
  errorMessage       String?           @map("error_message")
  createdAt          DateTime          @default(now()) @map("created_at")
  completedAt        DateTime?         @map("completed_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdByUser User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([institutionId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([status])
  @@map("analysis_runs")
}

model IngestionLog {
  id               String             @id @default(cuid())
  institutionId    String?            @map("institution_id")
  createdByUserId  String             @map("created_by_user_id") @db.Uuid
  reportJobId      String?            @map("report_job_id")
  source           String             @default("manual_upload")
  sourceFilename   String?            @map("source_filename")
  schemaVersion    String             @default("alm_csv_v1") @map("schema_version")
  status           IngestionLogStatus
  dryRun           Boolean            @default(false) @map("dry_run")
  totalRows        Int                @default(0) @map("total_rows")
  validRows        Int                @default(0) @map("valid_rows")
  errorRows        Int                @default(0) @map("error_rows")
  totalAssets      Decimal            @default(0) @map("total_assets") @db.Decimal(18, 2)
  totalLiabilities Decimal            @default(0) @map("total_liabilities") @db.Decimal(18, 2)
  importedCount    Int                @default(0) @map("imported_count")
  warnings         Json?
  errors           Json?
  createdAt        DateTime           @default(now()) @map("created_at")

  institution Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  createdByUser User       @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([institutionId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([reportJobId, createdAt])
  @@map("ingestion_logs")
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String             @unique @map("user_id") @db.Uuid
  tier              SubscriptionTier   @default(free)
  status            SubscriptionStatus @default(active)
  stripeCustomerId  String?            @map("stripe_customer_id")
  stripeSessionId   String?            @map("stripe_session_id")
  stripePriceId     String?            @map("stripe_price_id")
  stripeSubscriptionId String?         @map("stripe_subscription_id")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  cancelledAt       DateTime?          @map("cancelled_at")
  reportsUsed       Int                @default(0) @map("reports_used")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

enum ReportJobStatus {
  AWAITING_DATA
  VALIDATING
  VALIDATION_FAILED
  QUEUED
  PROCESSING
  GENERATING_PDF
  UPLOADING
  COMPLETE
  FAILED
}

model ReportJob {
  id                  String          @id @default(cuid())
  userId              String          @map("user_id") @db.Uuid
  institutionId       String?         @map("institution_id")
  institutionName     String          @map("institution_name")
  status              ReportJobStatus @default(AWAITING_DATA)
  analysisPeriod      String?         @map("analysis_period")   // e.g. "Q1-2026", "Annual-2026"
  previousJobId       String?         @map("previous_job_id")   // links to prior period job for trend tracking
  submittedAt         DateTime?       @map("submitted_at")
  processingStartedAt DateTime?       @map("processing_started_at")
  completedAt         DateTime?       @map("completed_at")
  reportUrl           String?         @map("report_url")
  reportUrlEn         String?         @map("report_url_en")
  reportLang          String          @default("es") @map("report_lang")
  rawData             String?         @map("raw_data")       // AES-256-GCM encrypted CSV snapshot; nulled 90 days after completion
  rawDataPurgedAt     DateTime?       @map("raw_data_purged_at")
  errorMessage        String?         @map("error_message")
  retryCount          Int             @default(0) @map("retry_count")
  triggeredBy         String          @default("payment") @map("triggered_by")
  createdAt           DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@index([institutionId, status])
  @@index([createdAt])
  @@map("report_jobs")
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("magic_links")
}

model EmailSequence {
  id          String    @id @default(cuid())
  userId      String?   @map("user_id") @db.Uuid
  leadId      String?   @map("lead_id")
  sequenceKey String    @map("sequence_key")
  scheduledAt DateTime  @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  cancelled   Boolean   @default(false)
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId, sequenceKey])
  @@index([scheduledAt, cancelled, sentAt])
  @@map("email_sequences")
}

// ===== Partner White-Label =====

model PartnerConfig {
  id            String  @id @default(cuid())
  userId        String  @unique @map("user_id") @db.Uuid
  firmName      String  @map("firm_name")
  firmLogoUrl   String? @map("firm_logo_url")
  firmAddress   String? @map("firm_address")
  coverFooter   String? @map("cover_footer")
  primaryColor  String  @default("#1B3A6B") @map("primary_color")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("partner_configs")
}

// ===== Legacy Prospect CRM =====

enum ProspectStage {
  lead
  contacted
  demo_scheduled
  demo_done
  proposal
  closed_won
  closed_lost
}

model Prospect {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  email     String?
  company   String?
  role      String?
  stage     ProspectStage @default(lead)
  source    String?       // demo_request | manual | referral | outbound
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([stage])
  @@index([email])
  @@map("prospects")
}

// ===== OCIF Audit Compliance =====

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  institutionId String?  @map("institution_id")
  action        String   // login, data_upload, report_download, team_invite, payment_initiated, settings_change, data_deleted
  resource      String   // alm_report, institution, user, subscription, magic_link
  resourceId    String?  @map("resource_id")
  outcome       String   @default("success") // success, failure, denied
  changes       Json?
  metadata      Json?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  tenantId      String?  @map("tenant_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([resource, resourceId])
  @@index([userId, createdAt])
  @@index([institutionId, createdAt])
  @@index([action])
  @@index([tenantId])
  @@map("audit_logs")
}

// ===== Feedback / NPS =====

model Feedback {
  id            String    @id @default(cuid())
  institutionId String?   @map("institution_id")
  jobId         String?   @map("job_id")
  npsScore      Int?      @map("nps_score")
  comment       String?
  contactOk     Boolean   @default(false) @map("contact_ok")
  respondedAt   DateTime? @map("responded_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([institutionId])
  @@index([jobId])
  @@map("feedback")
}

// ===== Phase VI: Growth Platform Models =====

model WebhookSubscription {
  id             String   @id @default(cuid())
  institutionId  String   @map("institution_id")
  url            String   // target URL for webhook delivery
  events         String[] // ["policy.breach","rate.move","compliance.deadline","report.ready","ews.alert"]
  secretKey      String   @map("secret_key") // HMAC-SHA256 signing key
  isActive       Boolean  @default(true) @map("is_active")
  lastDeliveredAt DateTime? @map("last_delivered_at")
  failureCount   Int      @default(0) @map("failure_count")
  createdAt      DateTime @default(now()) @map("created_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([isActive])
  @@map("webhook_subscriptions")
}

model Reseller {
  id              String   @id @default(cuid())
  name            String   // "Ernst & Young PR"
  slug            String   @unique // "ey-pr" → ey-pr.cerniq.io
  logoUrl         String?  @map("logo_url")
  primaryColor    String   @default("#1B3A6B") @map("primary_color")
  domain          String?  // custom domain: alm.ey-pr.com
  revenueSharePct Decimal  @map("revenue_share_pct") @db.Decimal(8, 6) // 0.20 = 20%
  billingModel    String   @default("PASS_THROUGH") @map("billing_model") // PASS_THROUGH | RESELLER_BILLS
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("resellers")
}

model ProspectAnalysis {
  id              String    @id @default(cuid())
  charterNumber   String    @map("charter_number")
  institutionName String    @map("institution_name")
  totalAssets     Decimal   @map("total_assets") @db.Decimal(18, 2)
  riskFlags       Json      @map("risk_flags")
  emailDraft      String?   @map("email_draft")
  emailDraftEs    String?   @map("email_draft_es")
  overallRisk     String    @map("overall_risk") // HIGH | MEDIUM | LOW
  status          String    @default("analyzed") // analyzed | email_sent | opened | replied
  sentAt          DateTime? @map("sent_at")
  openedAt        DateTime? @map("opened_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([charterNumber])
  @@index([status])
  @@index([overallRisk])
  @@map("prospect_analyses")
}

// ===== Phase VII: Enterprise Infrastructure Models =====

model SSOConfiguration {
  id              String   @id @default(cuid())
  institutionId   String   @unique @map("institution_id")
  protocol        String   // "SAML2" | "OIDC"
  samlEntityId    String?  @map("saml_entity_id")
  samlIdpUrl      String?  @map("saml_idp_url")
  samlIdpCert     String?  @map("saml_idp_cert") // PEM-encoded
  oidcIssuer      String?  @map("oidc_issuer")
  oidcClientId    String?  @map("oidc_client_id")
  oidcClientSecret String? @map("oidc_client_secret") // encrypted at rest
  jitProvisioning Boolean  @default(true) @map("jit_provisioning")
  defaultRole     String   @default("viewer") @map("default_role")
  groupRoleMapping Json?   @map("group_role_mapping") // { "admins": "cfo", "board": "board_member" }
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("sso_configurations")
}

model UsageMeterEvent {
  id              String   @id @default(cuid())
  institutionId   String   @map("institution_id")
  eventType       String   @map("event_type") // compute_job | api_call | report_generated | seat
  quantity        Int      @default(1)
  metadata        Json?
  billedAt        DateTime? @map("billed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([institutionId, eventType, createdAt])
  @@index([billedAt])
  @@map("usage_meter_events")
}

model DataDeletionRequest {
  id              String    @id @default(cuid())
  institutionId   String    @map("institution_id")
  requestedBy     String    @map("requested_by") // userId
  regulation      String    // GDPR | CCPA | PR_ACT_81
  status          String    @default("pending") // pending | processing | completed | rejected
  dataScope       String    @map("data_scope") // full | member_pii_only
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([institutionId])
  @@index([status])
  @@index([requestedBy])
  @@map("data_deletion_requests")
}

// ===== V6+V7: AI Research & Quant Expansion Models =====

model RegulatoryPublication {
  id          String    @id @default(cuid())
  url         String    @unique
  title       String
  regulator   String    // COSSEC | OCIF | NCUA
  publishedAt DateTime  @map("published_at")
  rawText     String    @db.Text
  impactJson  Json?     @map("impact_json")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  alerts InstitutionAlert[]

  @@map("regulatory_publications")
}

model InstitutionAlert {
  id                String    @id @default(cuid())
  institutionId     String    @map("institution_id")
  publicationId     String    @map("publication_id")
  severity          String    // HIGH | MEDIUM | LOW
  alertTextEs       String    @db.Text @map("alert_text_es")
  alertTextEn       String?   @db.Text @map("alert_text_en")
  affectedItems     String[]  @map("affected_items")
  recommendedAction String    @db.Text @map("recommended_action")
  readAt            DateTime? @map("read_at")
  dismissedAt       DateTime? @map("dismissed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  institution Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  publication RegulatoryPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@index([institutionId, createdAt(sort: Desc)])
  @@index([publicationId])
  @@map("institution_alerts")
}

// ===== Webhook Idempotency =====

model ProcessedWebhookEvent {
  id          String   @id // Stripe event ID (evt_...)
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_webhook_events")
}
