{
  "name": "cerniq-api",
  "version": "1.0.0",
  "description": "CerniQ ALM Reporting API — Asset-Liability Management for Puerto Rico Financial Institutions",
  "author": "KLYTICS LLC <legal@cerniq.io>",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" && npm run verify:tenant-scope && npm run verify:no-orphan-spec && npm run verify:no-focused-tests && npm run verify:d1-no-silent-fallback && npm run verify:no-silent-catch && npm run verify:accent-lint && npm run verify:auth-coverage && npm run verify:body-trust && npm run verify:rule-4-audit-immutable && npm run verify:rule-9-stamping && npm run verify:rule-11-any-rationale && npm run verify:rule-12-crypto-randomness && npm run verify:coverage-floor && npm run verify:gate-selftest && npx tsc --noEmit",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "verify:tenant-scope": "node scripts/verify-institution-scope-guard.mjs",
    "verify:institution-scope": "node scripts/verify-institution-scope-guard.mjs",
    "verify:no-orphan-spec": "node scripts/verify-no-orphan-spec.mjs",
    "verify:no-focused-tests": "node scripts/verify-no-focused-tests.mjs",
    "verify:d1-no-silent-fallback": "node scripts/verify-d1-no-silent-fallback.mjs",
    "verify:no-silent-catch": "node scripts/verify-no-silent-catch.mjs",
    "verify:accent-lint": "node scripts/verify-accent-lint.mjs",
    "verify:auth-coverage": "node scripts/verify-auth-coverage.mjs --strict",
    "verify:body-trust": "node scripts/verify-body-trust.mjs --strict",
    "verify:rule-4-audit-immutable": "node scripts/verify-rule-4-audit-immutable.mjs",
    "verify:rule-9-stamping": "node scripts/verify-rule-9-stamping.mjs",
    "verify:rule-11-any-rationale": "node scripts/verify-rule-11-any-rationale.mjs",
    "verify:rule-12-crypto-randomness": "node scripts/verify-rule-12-crypto-randomness.mjs",
    "verify:coverage-floor": "node scripts/verify-coverage-floor.mjs",
    "verify:gate-selftest": "node scripts/verify-gate-selftest.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:status": "bash ./scripts/prisma-migrate-safe.sh status",
    "prisma:deploy": "bash ./scripts/prisma-migrate-safe.sh apply",
    "prisma:generate": "prisma generate",
    "seed:institution": "npx ts-node scripts/seed-institution.ts",
    "seed:portal-submit": "npx ts-node scripts/seed-portal-submit.ts",
    "demo:provision": "npx ts-node scripts/provision-demo-portal.ts",
    "demo:list": "npx ts-node scripts/provision-demo-portal.ts --list",
    "exports:test": "npx ts-node scripts/test-file-exports.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/s3-request-presigner": "^3.1018.0",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.21",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nestjs": "^10.46.0",
    "@sentry/nextjs": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "@supabase/supabase-js": "^2.93.2",
    "@types/ioredis": "^4.28.10",
    "@types/pdfkit": "^0.17.5",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcrypt": "^6.0.0",
    "bottleneck": "^2.19.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "coingecko-api": "^1.0.10",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "csv-parser": "^3.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "openai": "^6.21.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.0",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0",
    "yahoo-finance2": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.21",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4",
    "qs": "6.15.0",
    "socket.io-parser": "4.2.6",
    "fast-xml-parser": "5.7.0",
    "uuid": "$uuid",
    "svix": "1.92.2",
    "@hono/node-server": "1.19.13",
    "@sentry/webpack-plugin": "5.2.0",
    "postcss": "^8.5.10"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "statements": 86,
        "branches": 70,
        "functions": 81,
        "lines": 86
      }
    },
    "testEnvironment": "node",
    "setupFiles": [
      "./test-setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ]
  }
}
