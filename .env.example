# Database Configuration
DATABASE_URL=postgresql://capexcycle:dev_password_change_in_prod@localhost:5433/capexcycle
DATABASE_PASSWORD=dev_password_change_in_prod

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Authentication (REQUIRED — min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# OAuth — Google (optional, leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OAuth — GitHub (optional, leave blank to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Frontend URL (for OAuth callback redirects)
FRONTEND_URL=http://localhost:3001

# API Keys - Market Data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
COINGECKO_API_KEY=your_coingecko_key
YAHOO_FINANCE_API_KEY=optional

# API Keys - LLM/AI
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
# Use Ollama for local LLM (set to true to use local models)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434

# AWS S3 Configuration (for SpendCheck receipts)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=spendcheck-receipts
S3_PRESIGNED_URL_EXPIRY=300

# Analytics (optional — leave blank to disable)
NEXT_PUBLIC_SEGMENT_WRITE_KEY=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=

# Server Configuration
BACKEND_PORT=8001
FRONTEND_PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# WebSocket Configuration
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL=30

# Logging
RUST_LOG=info,backend=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_AI_INSIGHTS=true
ENABLE_CRYPTO_DATA=true

# Performance
DATABASE_POOL_SIZE=20
REDIS_POOL_SIZE=10
