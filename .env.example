# Database Configuration
DATABASE_URL=postgresql://cerniq:dev_password_change_in_prod@localhost:5433/cerniq
DATABASE_PASSWORD=dev_password_change_in_prod

# Redis Configuration
REDIS_URL=redis://localhost:6380

# JWT Authentication (REQUIRED — min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# Master account password (REQUIRED in production)
# Bootstraps the canonical platform-owner account. Auth service falls back
# to a dev default if unset in non-production; production WILL fail closed.
MASTER_ACCOUNT_PASSWORD=change_me_master_account_password

# Unified Supabase auth (K-Lytics / keysworkspace)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# Legacy aliases still read by some server paths
SUPABASE_AUDIENCE=authenticated
SUPABASE_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
KLYTICS_APP_ID=cerniq
KLYTICS_REQUIRE_ORG=false
KLYTICS_REQUIRE_ENTITLEMENT=false
AUTH_ALLOW_LEGACY=true
API_KEY_PEPPER=

# OAuth — Google (optional, leave blank to disable)
# Production contract:
# - Google OAuth client type must be Web application
# - Authorized JavaScript origins: https://cerniq.io, https://api.cerniq.io
# - Authorized redirect URI: https://api.cerniq.io/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OAuth — GitHub (optional, leave blank to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Frontend URL (for OAuth callback redirects and CORS)
FRONTEND_URL=http://localhost:3001

# Auth cookie hardening
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.cerniq.io
# PLATFORM_RECOVERY_OWNER_BYPASS=true

# Frontend API URL (NestJS backend)
NEXT_PUBLIC_NODE_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Legacy frontend aliases still supported by some pages/components
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:3000
# OAuth button toggles (frontend)
NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=true
NEXT_PUBLIC_ENABLE_GITHUB_OAUTH=false

# Production reference (Vercel + Railway custom domains)
# FRONTEND_URL=https://cerniq.io
# NEXT_PUBLIC_APP_URL=https://cerniq.io
# NEXT_PUBLIC_NODE_API_URL=https://api.cerniq.io
# API_URL=https://api.cerniq.io
# GITHUB_CALLBACK_URL=https://api.cerniq.io/api/auth/github/callback
# GOOGLE_CALLBACK_URL=https://api.cerniq.io/api/auth/google/callback

# API Keys - Market Data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
COINGECKO_API_KEY=your_coingecko_key
YAHOO_FINANCE_API_KEY=optional

# API Keys - LLM/AI
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BETA_HEADER=tools-2024-04-04

# Agent Execution Layer (Vol2 §Deployment)
AGENT_WORKER_CONCURRENCY=5
MAX_AGENT_TOKENS=8192
LLM_COST_ALERT_THRESHOLD_USD=100
AUDIT_LOG_RETENTION_DAYS=2555
SSE_HEARTBEAT_INTERVAL_MS=30000

# Use Ollama for local LLM (set to true to use local models)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434

# AWS S3 Configuration (for SpendCheck receipts)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_ENDPOINT=
AWS_REGION=us-east-1
AWS_S3_BUCKET=spendcheck-receipts
S3_PRESIGNED_URL_EXPIRY=300

# Analytics (optional — leave blank to disable)
NEXT_PUBLIC_SEGMENT_WRITE_KEY=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=

# Server Configuration
BACKEND_PORT=3000
FRONTEND_PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Alias still honored by the backend
CORS_ORIGIN=
# Keep preview origins disabled unless explicitly needed
ALLOW_PREVIEW_ORIGINS=false
# Restrict Vercel preview origin matching to your project scope when enabled
# VERCEL_PREVIEW_ORIGIN_REGEX=^https://[a-z0-9-]+-ekiess-projects\\.vercel\\.app$

# Health diagnostics exposure
# In production, detailed health defaults to hidden unless explicitly enabled
HEALTH_DETAILS_PUBLIC=false

# Frontend demo/mock fallback controls
# Keep disabled in production unless you intentionally want synthetic data
ALLOW_DEMO_MOCKS=false
NEXT_PUBLIC_ALLOW_DEMO_MOCKS=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# WebSocket Configuration
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL=30
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_WS_URL=

# Logging (NestJS uses Pino — Rust backend removed)
LOG_FORMAT=json

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_AI_INSIGHTS=true
ENABLE_CRYPTO_DATA=true

# Interest-rate stress testing defaults
FED_FUNDS_RATE_BPS=450

# Data Encryption (REQUIRED for PII at rest — generate with: openssl rand -hex 32)
DATA_ENCRYPTION_KEY=

# Admin
ADMIN_KEY=your-admin-key-change-in-production
# Prospect seed data (JSON array — keeps PII out of source code)
# PROSPECT_SEED_DATA=[{"name":"...","email":"...","company":"...","role":"...","stage":"lead","source":"outbound","notes":"..."}]

# Stripe Billing (SAAS-01)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ONE_TIME=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_PARTNER=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudflare R2 / S3-compatible Storage (for report PDFs)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cerniq-reports

# Email (Resend)
RESEND_API_KEY=re_...
ERWIN_EMAIL=eskiessalfonso@gmail.com
SLACK_WEBHOOK_URL=

# Performance
DATABASE_POOL_SIZE=20
REDIS_POOL_SIZE=10

# Runtime port (usually injected by Railway/Vercel/containers)
PORT=3000
